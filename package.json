{
  "name": "app-barkod-analiz-v1",
  "version": "1.0.1",
  "description": "BarkodAnaliz Profesyonel Gıda ve Barkod Analiz Uygulaması",
  "author": "ErEnesAl®",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "clean": "watchman watch-del-all || true && rm -rf .expo node_modules /tmp/metro-cache && npm install",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "market-gelsin:seed-runtime": "node ./scripts/seed-market-gelsin-runtime.mjs",
    "market-gelsin:seed-runtime:from-env": "node ./scripts/seed-market-gelsin-runtime.mjs --from-env",
    "doctor": "npx expo-doctor",
    "check": "npm run type-check && npm run lint && npm run doctor",
    "bundle:android:release": "cd android && ./gradlew :app:bundleRelease",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "axios": "^1.13.6",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.8",
    "expo-auth-session": "~55.0.7",
    "expo-av": "^16.0.8",
    "expo-camera": "~55.0.9",
    "expo-crypto": "~55.0.9",
    "expo-image-picker": "~55.0.11",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "^55.0.13",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "firebase": "^12.10.0",
    "i18next": "^25.8.14",
    "react": "19.2.0",
    "react-i18next": "^16.5.5",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-purchases": "^9.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "^55.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.2.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
