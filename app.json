{
  "expo": {
    "name": "BarkodAnaliz ErEnesAl®",
    "slug": "app-barkod-analiz-v1",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "erenesal",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/app-icon-barkodanaliz.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ersat.barkodanaliz",
      "buildNumber": "1.0.1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "BarkodAnaliz, ürün barkodlarını tarayabilmek için kamera erişimine ihtiyaç duyar.",
        "NSPhotoLibraryUsageDescription": "Eksik ürün bildirimi için ürün görseli seçebilmek adına fotoğraf arşivinize erişim gerekir.",
        "NSLocationWhenInUseUsageDescription": "BarkodAnaliz, size yakın market tekliflerini ve konuma göre fiyat karşılaştırmasını gösterebilmek için konum erişimine ihtiyaç duyar."
      }
    },
    "android": {
      "package": "com.ersat.erenesalv1",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-barkodanaliz.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "INTERNET",
        "com.android.vending.BILLING",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod tarama işlemi için kamera erişimi gereklidir."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Eksik ürün bildirimi için galeri görseli seçebilmek adına fotoğraf arşivinize erişim gerekir.",
          "cameraPermission": "Eksik ürün bildirimi için ürün fotoğrafı çekebilmek adına kamera erişimi gerekir."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BarkodAnaliz, size yakın market tekliflerini ve konuma göre fiyat karşılaştırmasını gösterebilmek için konum erişimine ihtiyaç duyar."
        }
      ],
      "expo-font",
      "expo-audio",
      "expo-asset",
      "expo-localization",
      "expo-notifications",
      "expo-apple-authentication",
      "expo-sqlite",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-system-ui",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9503865696579023~4685281890",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true
        }
      ]
    ],
    "extra": {
      "firebaseProjectId": "barkodanaliz-5ed4b",
      "eas": {
        "projectId": "3294399e-b8b5-42fe-973b-b8e2609470a1"
      }
    }
  }
}
