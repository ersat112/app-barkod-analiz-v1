{
  "expo": {
    "name": "BarkodAnaliz ErEnesAl®",
    "slug": "app-barkod-analiz-v1",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "erenesal",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ersat.erenesalv1",
      "buildNumber": "1.0.0",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "BarkodAnaliz, ürün barkodlarını tarayabilmek için kamera erişimine ihtiyaç duyar."
      }
    },
    "android": {
      "package": "com.ersat.erenesalv1",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "CAMERA",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod tarama işlemi için kamera erişimi gereklidir."
        }
      ],
      "expo-apple-authentication",
      "expo-system-ui",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9503865696579023~2458617965",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true
        }
      ]
    ],
    "extra": {
      "firebaseProjectId": "barkodanaliz-5ed4b",
      "eas": {
        "projectId": "3294399e-b8b5-42fe-973b-b8e2609470a1"
      }
    }
  }
}
