# Copy everything from .gitignore first because EAS prefers .easignore when present.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
ios/Pods/
ios/build/
android/build/
android/app/build/
android/app/.cxx/
android/.gradle/

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
!.env.example
.env*.local

# typescript
*.tsbuildinfo

# Include the local build-time env file for EAS cloud builds.
!.env
