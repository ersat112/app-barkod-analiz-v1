rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function firestoreRolloutPath() {
      return /databases/$(database)/documents/runtime_config/firestore_rollout;
    }

    function firestoreRolloutExists() {
      return exists(firestoreRolloutPath());
    }

    function allowClientSharedCacheWrites() {
      return firestoreRolloutExists()
        && get(firestoreRolloutPath()).data.allowClientSharedCacheWrites == true;
    }

    function allowClientSharedCacheReads() {
      return firestoreRolloutExists()
        && get(firestoreRolloutPath()).data.allowSharedCacheReads == true;
    }

    function allowClientAnalyticsWrites() {
      return !firestoreRolloutExists()
        || get(firestoreRolloutPath()).data.allowClientAnalyticsWrites == true;
    }

    function allowUserScanHistoryWrites() {
      return firestoreRolloutExists()
        && get(firestoreRolloutPath()).data.allowUserScanHistoryWrites == true;
    }

    function allowMissingProductContributionWrites() {
      return firestoreRolloutExists()
        && get(firestoreRolloutPath()).data.allowMissingProductContributionWrites == true;
    }

    function allowRuntimeConfigRead(docId) {
      return isSignedIn()
        && (
          docId == 'ad_policy'
          || docId == 'firestore_rollout'
          || docId == 'monetization_policy'
        );
    }

    function isValidBarcodeId(barcode) {
      return barcode is string && barcode.matches('^[0-9]{8,14}$');
    }

    function isAllowedPlatform(value) {
      return value is string
        && (value == 'ios' || value == 'android' || value == 'web' || value == 'native');
    }

    function isAllowedEnvironment(value) {
      return value is string
        && (value == 'development' || value == 'production');
    }

    function isOptionalString(value) {
      return value == null || value is string;
    }

    function isOptionalNumber(value) {
      return value == null || value is int || value is float;
    }

    function isOptionalTimestamp(value) {
      return value == null || value is timestamp;
    }

    function isOptionalBoolean(value) {
      return value == null || value is bool;
    }

    function isOptionalMap(value) {
      return value == null || value is map;
    }

    function isOptionalNutritionPreferencesMap(value) {
      return value == null
        || (
          value is map
          && value.keys().hasOnly([
            'glutenFree',
            'lactoseFree',
            'palmOilFree',
            'vegetarian',
            'vegan'
          ])
          && isOptionalBoolean(value.glutenFree)
          && isOptionalBoolean(value.lactoseFree)
          && isOptionalBoolean(value.palmOilFree)
          && isOptionalBoolean(value.vegetarian)
          && isOptionalBoolean(value.vegan)
        );
    }

    function isOptionalLegalAcceptanceMap(value) {
      return value == null
        || (
          value is map
          && value.keys().hasOnly([
            'acceptedAt',
            'versionLabel',
            'source',
            'documents'
          ])
          && isOptionalStringOrTimestamp(value.acceptedAt)
          && isOptionalString(value.versionLabel)
          && (
            value.source == null
            || (
              value.source is string
              && (
                value.source == 'signup'
                || value.source == 'first_auth'
                || value.source == 'profile_sync'
                || value.source == 'manual_refresh'
              )
            )
          )
          && (
            value.documents == null
            || (
              value.documents is map
              && value.documents.keys().hasOnly([
                'terms',
                'privacy',
                'medical',
                'premium',
                'independence'
              ])
              && isOptionalString(value.documents.terms)
              && isOptionalString(value.documents.privacy)
              && isOptionalString(value.documents.medical)
              && isOptionalString(value.documents.premium)
              && isOptionalString(value.documents.independence)
            )
          )
        );
    }

    function isOptionalStringList(value) {
      return value == null || value is list;
    }

    function isOptionalStringOrTimestamp(value) {
      return value == null || value is string || value is timestamp;
    }

    function isValidSharedCacheStatus(value) {
      return value is string && (value == 'found' || value == 'not_found');
    }

    function isValidSharedCachePayload(data, barcode) {
      return data.barcode == barcode
        && isValidBarcodeId(data.barcode)
        && isValidSharedCacheStatus(data.cacheStatus)
        && isOptionalString(data.sourceName)
        && isOptionalString(data.productType)
        && isOptionalMap(data.productPayload)
        && (data.schemaVersion is int || data.schemaVersion is float)
        && (data.fetchedAt is int || data.fetchedAt is float)
        && (data.expiresAt is int || data.expiresAt is float)
        && isOptionalTimestamp(data.createdAt)
        && isOptionalTimestamp(data.updatedAt)
        && data.writerUid is string
        && data.writerUid == request.auth.uid
        && isAllowedPlatform(data.writerPlatform)
        && (
          (data.cacheStatus == 'found' && data.productPayload is map)
          || (data.cacheStatus == 'not_found' && data.productPayload == null)
        );
    }

    function isValidAnalyticsEvent(data) {
      return data.keys().hasOnly([
          'eventId',
          'eventName',
          'installationId',
          'sessionId',
          'platform',
          'environment',
          'clientCreatedAt',
          'receivedAt',
          'payload',
          'authUid'
        ])
        && data.eventId is string
        && data.eventName is string
        && data.installationId is string
        && data.sessionId is string
        && isAllowedPlatform(data.platform)
        && isAllowedEnvironment(data.environment)
        && (data.clientCreatedAt is int || data.clientCreatedAt is float)
        && data.receivedAt is timestamp
        && data.payload is map
        && data.authUid is string
        && data.authUid == request.auth.uid;
    }

    function isValidMissingProductContribution(data) {
      return data.keys().hasOnly([
          'localId',
          'barcode',
          'name',
          'brand',
          'country',
          'origin',
          'ingredients_text',
          'notes',
          'type',
          'image_url',
          'image_status',
          'source',
          'source_screen',
          'entry_point',
          'review_status',
          'review_queue_status',
          'moderation_state',
          'moderation_version',
          'contribution_version',
          'platform',
          'client_created_at',
          'client_updated_at',
          'client_last_sync_attempt_at',
          'local_status',
          'submitted_at',
          'updated_at',
          'authorUid'
        ])
        && isValidBarcodeId(data.barcode)
        && isOptionalString(data.localId)
        && isOptionalString(data.name)
        && isOptionalString(data.brand)
        && isOptionalString(data.country)
        && isOptionalString(data.origin)
        && isOptionalString(data.ingredients_text)
        && isOptionalString(data.notes)
        && isOptionalString(data.image_url)
        && data.type is string
        && (
          data.type == 'food'
          || data.type == 'beauty'
          || data.type == 'medicine'
          || data.type == 'unknown'
        )
        && data.image_status is string
        && (
          data.image_status == 'none'
          || data.image_status == 'pending_upload'
          || data.image_status == 'uploaded'
        )
        && data.source is string
        && data.source_screen is string
        && data.entry_point is string
        && (data.entry_point == 'detail_not_found' || data.entry_point == 'manual')
        && data.review_status is string
        && (
          data.review_status == 'pending'
          || data.review_status == 'approved'
          || data.review_status == 'rejected'
        )
        && data.review_queue_status is string
        && (
          data.review_queue_status == 'local_draft'
          || data.review_queue_status == 'queued_remote'
          || data.review_queue_status == 'synced_remote'
        )
        && data.moderation_state is string
        && (data.moderation_version is int || data.moderation_version is float)
        && (data.contribution_version is int || data.contribution_version is float)
        && isAllowedPlatform(data.platform)
        && isOptionalStringOrTimestamp(data.client_created_at)
        && isOptionalStringOrTimestamp(data.client_updated_at)
        && isOptionalStringOrTimestamp(data.client_last_sync_attempt_at)
        && isOptionalString(data.local_status)
        && isOptionalTimestamp(data.submitted_at)
        && isOptionalTimestamp(data.updated_at)
        && data.authorUid is string
        && data.authorUid == request.auth.uid;
    }

    function isValidScanHistoryEntry(data) {
      return data.keys().hasOnly([
          'barcode',
          'name',
          'brand',
          'image_url',
          'type',
          'source_name',
          'score',
          'grade',
          'risk_level',
          'country',
          'origin',
          'scanned_at',
          'synced_at',
          'client_enqueued_at'
        ])
        && isValidBarcodeId(data.barcode)
        && isOptionalString(data.name)
        && isOptionalString(data.brand)
        && isOptionalString(data.image_url)
        && data.type is string
        && (
          data.type == 'food'
          || data.type == 'beauty'
          || data.type == 'medicine'
        )
        && isOptionalString(data.source_name)
        && (data.score is int || data.score is float)
        && isOptionalString(data.grade)
        && data.risk_level is string
        && (
          data.risk_level == 'low'
          || data.risk_level == 'medium'
          || data.risk_level == 'high'
        )
        && isOptionalString(data.country)
        && isOptionalString(data.origin)
        && isOptionalStringOrTimestamp(data.scanned_at)
        && isOptionalTimestamp(data.synced_at)
        && isOptionalStringOrTimestamp(data.client_enqueued_at);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && isOptionalString(request.resource.data.firstName)
        && isOptionalString(request.resource.data.lastName)
        && isOptionalString(request.resource.data.displayName)
        && isOptionalString(request.resource.data.phone)
        && isOptionalString(request.resource.data.city)
        && isOptionalString(request.resource.data.district)
        && isOptionalString(request.resource.data.address)
        && isOptionalString(request.resource.data.email)
        && isOptionalString(request.resource.data.photoURL)
        && isOptionalStringList(request.resource.data.providerIds)
        && isOptionalBoolean(request.resource.data.emailVerified)
        && isOptionalBoolean(request.resource.data.kvkkAccepted)
        && isOptionalLegalAcceptanceMap(request.resource.data.legalAcceptance)
        && isOptionalNutritionPreferencesMap(request.resource.data.nutritionPreferences)
        && isOptionalMap(request.resource.data.monetization)
        && isOptionalStringOrTimestamp(request.resource.data.createdAt)
        && isOptionalStringOrTimestamp(request.resource.data.updatedAt)
        && isOptionalStringOrTimestamp(request.resource.data.lastLoginAt)
        && isOptionalStringOrTimestamp(request.resource.data.lastSeenAt);

      allow delete: if false;

      match /scan_history/{scanId} {
        allow read: if isSignedIn() && request.auth.uid == userId;

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && allowUserScanHistoryWrites()
          && isValidScanHistoryEntry(request.resource.data);

        allow delete: if false;
      }
    }

    match /runtime_config/{docId} {
      allow read: if allowRuntimeConfigRead(docId);
      allow write: if false;
    }

    match /shared_product_cache/{barcode} {
      allow read: if isSignedIn()
        && isValidBarcodeId(barcode)
        && allowClientSharedCacheReads();

      allow create, update: if isSignedIn()
        && isValidBarcodeId(barcode)
        && allowClientSharedCacheWrites()
        && isValidSharedCachePayload(request.resource.data, barcode);

      allow delete: if false;
    }

    match /analytics_events/{eventId} {
      allow read: if false;

      allow create: if isSignedIn()
        && allowClientAnalyticsWrites()
        && isValidAnalyticsEvent(request.resource.data);

      allow update, delete: if false;
    }

    match /missing_product_contributions/{docId} {
      allow create, update: if isSignedIn()
        && allowMissingProductContributionWrites()
        && isValidMissingProductContribution(request.resource.data);

      allow read: if isSignedIn()
        && resource.data.authorUid is string
        && resource.data.authorUid == request.auth.uid;

      allow update, delete: if false;
    }
  }
}
