{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "babel.config.js",
    "metro.config.js",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".expo",
    "android",
    "ios"
  ]
}